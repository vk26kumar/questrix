# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Local (docker-compose):
MONGODB_URI=mongodb://admin:questrix_secret@localhost:27017/questrix?authSource=admin
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/questrix?retryWrites=true&w=majority

# Redis
# Local (docker-compose):
REDIS_URL=redis://localhost:6379
# Production (Upstash):
# REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Production Frontend URL
# FRONTEND_URL=https://questrix.vercel.app